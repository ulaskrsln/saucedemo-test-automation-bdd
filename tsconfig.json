{
  "compilerOptions": {
    "target": "ES6",
    "module": "CommonJS",
    "moduleResolution": "node16",
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true
  },
  "include": [
    "features/**/*.ts",
    "steps/**/*.ts",
    "pages/**/*.ts",
    "support/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}